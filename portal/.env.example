# Secret used to sign session cookies. Generate with: openssl rand -base64 32
SESSION_SECRET=

# Shared password for Nuprotec's users
NUPROTEC_PASSWORD=

# GitHub Personal Access Token with read access to the client report repos
# (e.g. israelojeda1-ops/nuprotec-informes). Fine-grained PAT scoped to
# "Contents: Read-only" on that repo is enough.
GITHUB_TOKEN=
